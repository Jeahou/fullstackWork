package com.example.board.service;

import org.springframework.security.crypto.bcrypt.BCryptPasswordEncoder;
import org.springframework.stereotype.Service;

import com.example.board.dto.member.BoardMemberInsertDTO;
import com.example.board.mapper.BoardMemberMapper;
import com.example.board.vo.BoardMemberVO;
import com.example.board.vo.Role;

import lombok.RequiredArgsConstructor;

@Service
@RequiredArgsConstructor
public class BoardMemberService {
	private final BoardMemberMapper boardMemberMapper;
	private final BCryptPasswordEncoder bCryptPasswordEncoder;
	
	
	public void insertMember(BoardMemberInsertDTO requestDto) {
		
		//이메일 중복체크 로직
		//닉네임 중복체크 로직
		
		String rawPassword = requestDto.getPassword();
		String encodedPassword = bCryptPasswordEncoder.encode(rawPassword);
		System.out.println(encodedPassword);
		
		boardMemberMapper.insertMember(BoardMemberVO.builder()
										.email(requestDto.getEmail())
										.name(requestDto.getName())
										.nickName(requestDto.getNickName())
										.password(encodedPassword)
										.snsType("LOCAL")
										.role(Role.USER)
										.build());
		
	}
	
	public void loginMember(String email, String rawPassword) {
		
		BoardMemberVO member = boardMemberMapper.getbyEmailBoardMember(email);
		
		if(member == null) {
			throw new IllegalArgumentException("존재하지 않는 이메일입니다.");
		}
		
		if(!bCryptPasswordEncoder.matches(rawPassword, member.getPassword())) {
			throw new IllegalArgumentException("비밀번호가 일치 하지않습니다.");
		}
	}
}
