package com.example.board.service;

import java.time.format.DateTimeFormatter;
import java.util.ArrayList;
import java.util.List;
import java.util.stream.Collectors;

import org.springframework.stereotype.Service;

import com.example.board.dto.BoardCommentDTO;
import com.example.board.dto.BoardCommentInsertDTO;
import com.example.board.mapper.BoardCommentMapper;
import com.example.board.vo.BoardCommentVO;

import lombok.RequiredArgsConstructor;

@Service
@RequiredArgsConstructor
public class BoardCommentService {
	
	private final BoardCommentMapper boardCommentMapper;
	
	public void insertComment(BoardCommentInsertDTO dto) {
		BoardCommentVO vo = new BoardCommentVO(dto.getBoardId(), dto.getParentId(), dto.getContent(), dto.getMemberId());
		boardCommentMapper.insertComment(vo);
	}
	
	public List<BoardCommentDTO> getCommentList(Long id){
		List<BoardCommentVO> voList = boardCommentMapper.getCommentList(id);
		
		return voList.stream()
				.map(vo -> BoardCommentDTO.builder()
						.id(vo.getId())
						.boardId(vo.getBoardId())
						.parentId(vo.getParentId())
						.lvl(vo.getLvl())
						.content(vo.getContent())
						.author(vo.getAuthor())
						.createdAt(vo.getCreatedAt().format(DateTimeFormatter.ofPattern("yyyy-MM-dd HH:mm")))
						.build())
					.collect(Collectors.toList());
	}
}
