package com.example.board.service;

import java.io.File;
import java.time.format.DateTimeFormatter;
import java.util.ArrayList;
import java.util.HashMap;
import java.util.List;
import java.util.Map;

import org.springframework.beans.factory.annotation.Value;
import org.springframework.security.access.AccessDeniedException;
import org.springframework.stereotype.Service;
import org.springframework.transaction.annotation.Transactional;
import org.springframework.web.multipart.MultipartFile;

import com.example.board.dto.BoardAuthorDTO;
import com.example.board.dto.BoardDTO;
import com.example.board.dto.BoardInsertDTO;
import com.example.board.dto.BoardUpdateDTO;
import com.example.board.mapper.BoardFileMapper;
import com.example.board.mapper.BoardMapper;
import com.example.board.mapper.BoardMemberMapper;
import com.example.board.vo.BoardFileVO;
import com.example.board.vo.BoardMemberVO;
import com.example.board.vo.BoardVO;

import lombok.RequiredArgsConstructor;

@Service
@RequiredArgsConstructor
public class BoardService {
	private final BoardMapper boardMapper;
	private final BoardFileService boardFileService;
	private final BoardFileMapper boardFileMapper;
	private final BoardMemberMapper boardMemberMapper;
	
	@Value("${file.upload.dir}")
	private String uploadDri;
	
	//페이징 처리한 전체 리스트 조회
	public Map<String, Object> getBoardList(Map<String, Object> params){
		
		List<BoardAuthorDTO> dtoList = boardMapper.getBoardList(params);
 		
		int totalCount = boardMapper.getBoardTotalCount(params);
		
		Map<String, Object> result = new HashMap<>();
		
		result.put("content", dtoList);
		result.put("totalElements", totalCount);
		
		return result;
	}
	
	//게시판글 상세보기
	public BoardAuthorDTO getByIdBoard(Long id) {
		BoardVO vo = boardMapper.getByIdBoardVo(id);
		
		BoardMemberVO memberVo = boardMemberMapper.getbyIdBoardMember(vo.getMemberId());
		
		
		String localdate = vo.getCreatedAt().format(DateTimeFormatter.ofPattern("yyyy-MM-dd HH:mm")); 
		
		return BoardAuthorDTO.builder()
				.id(vo.getId())
				.title(vo.getTitle())
				.category(vo.getCategory())
				.content(vo.getContent())
				.author(memberVo.getNickName())
				.createdAt(localdate)
				.build();
	}
	
	//게시판 글쓰기
	@Transactional
	public void insertBoard(BoardInsertDTO dto, List<MultipartFile> files, Long memberId) {
		BoardVO vo = new BoardVO(dto.getCategory(), dto.getTitle(), dto.getContent(), memberId);
		boardMapper.insertBoardVo(vo);
		
		Long generatedBoardId = vo.getId();
		
		if(files != null && !files.isEmpty()) {
			boardFileService.uploadsFiles(generatedBoardId, files);
		}
	}
	
	//게시판 글 수정
	public void updateBoard(Long id, BoardUpdateDTO dto, List<MultipartFile> newFiles, List<Long> deleteFileIds) {
		BoardVO vo = new BoardVO(id, dto.getCategory(), dto.getTitle(), dto.getContent());
		boardMapper.updateBoardVo(vo);
		
		if(deleteFileIds != null && !deleteFileIds.isEmpty()) {
			for(Long fileId : deleteFileIds) {
				BoardFileVO fileVO = boardFileMapper.getbyIdFilesDownload(fileId);
				
				File physicalFile = new File(uploadDri + fileVO.getFilePath());
				if(physicalFile.exists()) {
					physicalFile.delete();
				}
				
				boardFileMapper.deleteFile(fileId);
			}
		}
		
		if(newFiles != null && !newFiles.isEmpty()) {
			boardFileService.uploadsFiles(id, newFiles);
		}
	}
	
	//게시글 소프트 삭제
	public void deleteBoard(Long id, Long requesterId) {
		
		Long authorId = boardMapper.getBoardAuthorId(id);
		
		if(authorId == null) {
			throw new IllegalArgumentException("존재하지 않거나 이미 삭제된 게시글입니다.");
		}
		
		if(!authorId.equals(requesterId)) {
			throw new AccessDeniedException("본인이 작성한 글만 삭제할 수 있습니다.");
		}
		boardMapper.deleteBoardVo(id);
	}
}
