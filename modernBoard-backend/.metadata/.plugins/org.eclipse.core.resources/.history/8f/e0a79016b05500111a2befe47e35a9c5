<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
  
  <mapper namespace="com.example.board.mapper.BoardMapper">
  <select id="getBoardList" resultType="BoardAuthorDTO" parameterType="map">
	    SELECT  
	        ID,  
	        CATEGORY,  
	        TITLE,  
	        CONTENT,  
	        MEMBER_ID,  
	        AUTHOR,     
	        CREATED_AT  
	     FROM (
	        SELECT  
	            A.*,  
	            ROWNUM AS RN
	        FROM (
	            SELECT  
	                b.ID,  
	                b.CATEGORY,  
	                b.TITLE,  
	                b.CONTENT,  
	                b.MEMBER_ID,  
	                m.NICKNAME AS AUTHOR, -- 🌟 회원 테이블에서 닉네임을 가져와 AUTHOR로 매핑
	                TO_CHAR(b.CREATED_AT, 'YYYY-MM-DD HH24:MI') AS CREATED_AT -- 🌟 SQL에서 날짜 포맷팅까지 처리
	            FROM  
	                MODERNBOARD b
	            JOIN 
	                MODERNBOARD_MEMBER m ON b.MEMBER_ID = m.ID -- 🌟 회원 테이블 PK와 게시판 테이블 FK 조인
	            <where>
	                b.DEL_YN = 'N'
	                <if test="category != null and category != ''">
	                    AND b.CATEGORY = #{category}
	                </if>
	                <if test="keyword != null and keyword != ''">
	                    <choose>
	                        <when test="searchType == 'title'">
	                            AND b.TITLE LIKE '%' || #{keyword} || '%'
	                        </when>
	                        <when test="searchType == 'content'">
	                            AND b.CONTENT LIKE '%' || #{keyword} || '%'
	                        </when>
	                        <when test="searchType == 'author'">
	                            AND m.NICKNAME LIKE '%' || #{keyword} || '%'
	                        </when>
	                    </choose>
	                </if>
	            </where>
	            ORDER BY b.ID DESC
	        ) A
	        WHERE ROWNUM <![CDATA[<=]]> #{offset} + #{size}
	    )
	    WHERE RN <![CDATA[>]]> #{offset}
	</select>
	
	<select id="getBoardTotalCount" resultType="int" parameterType="map">
	    SELECT 
	    	COUNT(ID)
	    FROM 
	    	MODERNBOARD
	    <where>
	    	DEL_YN = 'N'
	    	
	        <if test="category != null and category != ''">
	            AND CATEGORY = #{category}
	        </if>
	        <if test="keyword != null and keyword != ''">
	            <choose>
	                <when test="searchType == 'title'">
	                    AND TITLE LIKE '%' || #{keyword} || '%'
	                </when>
	                <!-- content, author 조건 동일하게 작성 -->
	            </choose>
	        </if>
	    </where>
	</select>
	
    
    <select id="getByIdBoardVo" resultType="BoardVO" parameterType="long">
    	SELECT
    		ID,
    		CATEGORY,
    		TITLE,
    		CONTENT,
    		MEMBER_ID,
    		CREATED_AT
    	FROM MODERNBOARD
    	WHERE ID = #{id}
    		AND DEL_YN = 'N'
    </select>
    
    <insert id="insertBoardVo" parameterType="BoardVO">
    	<selectKey keyProperty="id" resultType="long" order="BEFORE">
    		SELECT SEQ_MD_ID.NEXTVAL FROM DUAL
    	</selectKey>
    	INSERT INTO MODERNBOARD(
    		ID,
    		CATEGORY,
    		TITLE,
    		CONTENT,
    		MEMBER_ID,
    		CREATED_AT
    	) VALUES (
    		#{id},
    		#{category},
    		#{title},
    		#{content},
    		#{memberId},
    		SYSDATE
    	)
    </insert>
    
    <update id="updateBoardVo" parameterType="boardVO">
    	UPDATE 
    		MODERNBOARD 
    	SET
    		CATEGORY = #{category},
    		TITLE = #{title},
    		CONTENT = #{content}
    	WHERE 
    		ID = #{id}
    </update>
    
    <update id="deleteBoardVo" parameterType="long">
    	UPDATE
    		MODERNBOARD
    	SET
    		DEL_YN = 'Y'
    	WHERE 
    		ID = #{id}
    </update>
</mapper>