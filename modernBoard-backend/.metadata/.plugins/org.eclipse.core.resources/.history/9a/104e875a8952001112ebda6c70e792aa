<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
  
  <mapper namespace="com.example.board.mapper.BoardFileMapper">
  	<insert id="insertFile" parameterType="BoardFileVO">
  		INSERT INTO MODERNBOARD_FILE(
  				ID,
  				BOARD_ID,
  				ORIGINAL_NAME,
  				SAVED_NAME,
 				FILE_PATH,
  				FILE_SIZE
  		)VALUES(
  				SEQ_FILE_ID.NEXTVAL,
  				#{boardId},
  				#{originalName},
  				#{savedName},
  				#{filePath},
  				#{fileSize}
  		)
  	</insert>
  	
  	<select id="getbyIdFilesDownload" parameterType="long" resultType="BoardFileVO">
  		SELECT
  			ID,
  			BOARD_ID,
  			ORIGINAL_NAME,
  			SAVED_NAME,
  			FILE_PATH,
  			FILE_SIZE
  		FROM
  			MODERNBOARD_FILE
  		WHERE ID = #{id}
  	</select>
  	
  	<select id="getbyIdFiles" parameterType="long" resultType="BoardFileVO">
  		SELECT
  			ID,
  			BOARD_ID,
  			ORIGINAL_NAME,
  			SAVED_NAME,
  			FILE_PATH,
  			FILE_SIZE
  		FROM
  			MODERNBOARD_FILE
  		WHERE BOARD_ID = #{boardId}
  	</select>
  	
  	 <update id="deleteFile" parameterType="long">
    	UPDATE
    		MODERNBOARD
    	SET
    		DEL_YN = 'Y'
    	WHERE 
    		ID = #{id}
    </update>
  
  </mapper>