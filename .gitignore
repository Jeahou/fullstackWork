
#  통합 .gitignore 

# -------------------------------------------------------------------------
# 1. OS (운영체제) 임시 파일
# -------------------------------------------------------------------------
.DS_Store
Thumbs.db

# -------------------------------------------------------------------------
# 2. 공통 에디터 / IDE 설정 파일 (VS Code, IntelliJ, STS 등)
# -------------------------------------------------------------------------
.vscode/*
!.vscode/extensions.json
.idea
*.iws
*.iml
*.ipr
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

# -------------------------------------------------------------------------
# 3. Backend (Spring Boot / Maven)
# -------------------------------------------------------------------------
HELP.md
target/
.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# NetBeans 
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/
build/
!**/src/main/**/build/
!**/src/test/**/build/

# -------------------------------------------------------------------------
# 4. Frontend (React / Node.js / Yarn)
# -------------------------------------------------------------------------
# 패키지 및 빌드 결과물
node_modules/
dist/
dist-ssr/

# 로그 파일
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# -------------------------------------------------------------------------
# 5. 🚨 보안 및 사용자 업로드 파일 (절대 깃허브에 올라가면 안 되는 것들)
# -------------------------------------------------------------------------
# 프론트엔드 환경 변수 (API 주소 등)
*.local
frontend/.env

# 백엔드 DB 비밀번호, JWT 시크릿 키가 담긴 파일 
backend/src/main/resources/application.properties
backend/src/main/resources/application-jwt.properties

# 사용자가 게시판에 업로드한 이미지/첨부파일 폴더
uploads/