
#  통합 .gitignore 

# -------------------------------------------------------------------------
# 1. OS (운영체제) 임시 파일
# -------------------------------------------------------------------------
.DS_Store
Thumbs.db

# -------------------------------------------------------------------------
# 2. 공통 에디터 / IDE 설정 파일 (VS Code, IntelliJ, STS 등)
# -------------------------------------------------------------------------
.vscode/
.idea/
*.iws
*.iml
*.ipr
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

# -------------------------------------------------------------------------
# 3. Backend (Spring Boot / Maven)
# -------------------------------------------------------------------------
**/target/
**/HELP.md
**/.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# NetBeans 
/nbproject/private/
/nbbuild/
/nbdist/
/.nb-gradle/

!**/src/main/**/build/
!**/src/test/**/build/

# -------------------------------------------------------------------------
# 4. Frontend (React / Node.js / Yarn)
# -------------------------------------------------------------------------
# 패키지 및 빌드 결과물
**/node_modules/
**/build/
**/dist/
**/logs/
**/*.log

# 로그 파일
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# STS/Eclipse 내부 메타데이터 폴더 차단 (🌟 필수 추가)
**/`metadata`/

# -------------------------------------------------------------------------
# 5. 🚨 보안 및 사용자 업로드 파일 (절대 깃허브에 올라가면 안 되는 것들)
# -------------------------------------------------------------------------
# 프론트엔드 환경 변수 (API 주소 등)
**/*.local
**/.env

# 백엔드 DB 비밀번호, JWT 시크릿 키가 담긴 파일 
**/application.properties
**/application-jwt.properties

!**/application-template.properties
# 사용자가 게시판에 업로드한 이미지/첨부파일 폴더
**/uploads/